# Frontend (las VITE_* se bundlean en build, OK que sean públicas)
VITE_AUTH0_DOMAIN=<tenant>.us.auth0.com
VITE_AUTH0_CLIENT_ID=<client-id-de-la-app-spa>
VITE_AUTH0_AUDIENCE=https://horarios-uba/api

# Backend
AUTH0_DOMAIN=<tenant>.us.auth0.com           # mismo que VITE_AUTH0_DOMAIN
AUTH0_AUDIENCE=https://horarios-uba/api      # mismo que VITE_AUTH0_AUDIENCE
MP_ACCESS_TOKEN=APP_USR-xxx                  # token de Mercado Pago (test o prod)
MP_WEBHOOK_SECRET=xxx                        # de "Webhooks" en el panel MP
APP_URL=http://localhost:5173                # URL pública del FE (back_urls de MP)
APP_URL_BACKEND=http://localhost:8000        # URL pública del BE (notification_url)
SUBSCRIPTION_PRICE_ARS=3000
SUBSCRIPTION_DAYS=90

# Dev only — bypass de la verificación de firma del webhook MP. NO setear en prod.
# MP_SKIP_SIGNATURE=1
