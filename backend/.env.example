# Las variables principales (DATABASE_URL, etc.) se setean directamente
# en docker-compose.yml. Este archivo está acá por si querés correr el
# scraper o la API desde el host (fuera de Docker).
DATABASE_URL=postgresql://postgres:postgres@localhost:5437/horarios
SCRAPER_DELAY_SECONDS=0.5
SCRAPER_USER_AGENT=OrganizacionHorarios/0.1 (tomas@goheadlands.com)

# Firebase Admin: path al service account JSON descargado desde la consola
# de Firebase (Project settings → Service accounts → Generate new private key).
# El archivo está gitignored. En Render se sube como Secret File.
GOOGLE_APPLICATION_CREDENTIALS=./firebase-sa.json
