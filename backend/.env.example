# Las variables principales (DATABASE_URL, etc.) se setean directamente
# en docker-compose.yml. Este archivo está acá por si querés correr el
# scraper o la API desde el host (fuera de Docker).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/horarios
SCRAPER_DELAY_SECONDS=0.5
SCRAPER_USER_AGENT=OrganizacionHorarios/0.1 (tomas@goheadlands.com)
